# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Admin
ADMIN_PASSWORD=your-admin-password
MANAGER_PASSWORD=your-manager-password

# Session signing secrets — required. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without these, the barber/manager login cookies are signed with a hardcoded
# default that's visible in this public source — anyone could forge a valid
# session for any barber (their id is public via /api/barbers) or the manager.
BARBER_SESSION_SECRET=
MANAGER_SESSION_SECRET=

# WhatsApp via Twilio (optional — for admin notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+972XXXXXXXXX

# Email fallback via Resend (optional — used if Twilio not configured)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL_BARBER_DEFAULT=barber@example.com
